# Example backend/.env.example — copy to .env and fill values
SECRET_KEY=unsafe-dev-secret
DEBUG=1
ALLOWED_HOSTS=127.0.0.1,localhost

# MySQL example (recommended):
# Replace user, password, host, port, and dbname accordingly
DATABASE_URL=mysql://bb_user:yourpassword@127.0.0.1:3306/bookbazaar

# Redis (for Celery)
# REDIS_URL=redis://127.0.0.1:6379/0

# Razorpay (if used)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
